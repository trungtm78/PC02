// PC02 Case Management System - Prisma Schema
// TASK-2026-0225-001-STEP1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// RBAC: Role & Permission
// ─────────────────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String           // e.g. "read", "write", "delete"
  subject     String           // e.g. "Case", "User", "AuditLog"
  conditions  Json?            // ABAC conditions (optional JSON)
  description String?
  createdAt   DateTime         @default(now())

  roles       RolePermission[]

  @@unique([action, subject])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  username         String     @unique
  passwordHash     String
  firstName        String?
  lastName         String?
  workId           String?    // Mã cán bộ (e.g. PC02-001)
  phone            String?
  departmentId     String?    // ID đơn vị từ danh mục
  isActive         Boolean    @default(true)
  roleId           String
  refreshTokenHash String?    // hashed refresh token for rotation
  tokenVersion     Int        @default(0) // incremented on password change to invalidate existing JWTs
  canDispatch      Boolean    @default(false) // supplementary permission: read all + assign/reassign any record
  lastLoginAt      DateTime?
  // 2FA fields
  totpSecret           String?   // AES-256-GCM encrypted base32 secret
  totpEnabled          Boolean   @default(false)
  totpSetupPending     Boolean   @default(false)
  totpSetupPendingAt   DateTime?
  backupCodes          String[]
  backupCodeSalts      String[]
  lastTotpCode         String?   // replay protection — last used TOTP code in current window
  twoFaSetupAt         DateTime?
  twoFaUsedAt          DateTime? // OV-002: marks twoFaToken as consumed, survives restart
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  role                  Role       @relation(fields: [roleId], references: [id])
  auditLogs             AuditLog[]
  cases                 Case[]
  petitionsEntered      Petition[] @relation("PetitionEnteredBy")
  petitionsAssigned     Petition[] @relation("PetitionAssignedTo")
  incidentsAssigned     Incident[] @relation("IncidentInvestigator")
  incidentsCanBoNhap    Incident[] @relation("IncidentCanBoNhap")
  incidentsCreated      Incident[] @relation("IncidentCreatedBy")
  incidentStatusChanges IncidentStatusHistory[] @relation("IncidentStatusChangedBy")
  documents             Document[] // Tài liệu đã upload
  proposalsCreated      Proposal[] @relation("ProposalCreatedBy")
  guidanceRecords       GuidanceRecord[] @relation("GuidanceCreatedBy")
  exchangesCreated      Exchange[] @relation("ExchangeCreatedBy")
  exchangeMessages      ExchangeMessage[] @relation("ExchangeMessageSender")
  delegationsCreated    Delegation[] @relation("DelegationCreatedBy")
  conclusionsAuthored   Conclusion[] @relation("ConclusionAuthor")
  conclusionsApproved   Conclusion[] @relation("ConclusionApprover")
  statusChanges         CaseStatusHistory[] @relation("StatusChangedBy")
  investigationSupplementsCreated InvestigationSupplement[] @relation("SupplementCreatedBy")
  notifications         Notification[]
  userTeams             UserTeam[]
  grantsReceived        DataAccessGrant[] @relation("GrantReceived")
  grantsGiven           DataAccessGrant[] @relation("GrantGiven")
  abbreviations         UserAbbreviation[]
  devices               UserDevice[]
  overdueNotifications  OverdueNotification[]
  vksMeetingsCreated    VksMeetingRecord[]     @relation("VksMeetingCreatedBy")
  actionPlansCreated    SuspensionActionPlan[] @relation("ActionPlanCreatedBy")
  reportTdcCreated      ReportTdcDraft[]       @relation("ReportCreatedBy")
  reportTdcReviewed     ReportTdcDraft[]       @relation("ReportReviewedBy")
  reportTdcApproved     ReportTdcDraft[]       @relation("ReportApprovedBy")
  reportTdcRejected     ReportTdcDraft[]       @relation("ReportRejectedBy")

  @@map("users")
}

// ─────────────────────────────────────────────
// System Directories
// ─────────────────────────────────────────────

model Directory {
  id             String    @id @default(cuid())
  type           String    // e.g. "CRIME", "ORG", "LOCATION", "STATUS"
  code           String    // e.g. "VA", "T01"
  name           String
  description    String?
  parentId       String?
  order          Int       @default(0)
  isActive       Boolean   @default(true)
  abolishedAt    DateTime?  // null = active; set = abolished from this date (cải cách hành chính)
  replacedByCode String?   // code of successor unit after abolition
  metadata       Json?     // Specific data for each type
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([type, code])
  @@map("directories")
}

// ─────────────────────────────────────────────
// Regulatory Compliance Enums (BLTTHS 2015 / Luật Tố cáo 2018)
// ─────────────────────────────────────────────

enum LoaiNguonTin {
  TO_GIAC           // Tố giác của cá nhân (Điều 144 khoản 1a BLTTHS 2015)
  TIN_BAO           // Tin báo của cơ quan, tổ chức (Điều 144 khoản 1b)
  KIEN_NGHI_KHOI_TO // Kiến nghị khởi tố (Điều 144 khoản 1c)
}

enum LoaiDon {
  TO_CAO    // Tố cáo (Luật Tố cáo 2018)
  KHIEU_NAI // Khiếu nại (Luật Khiếu nại 2011)
  KIEN_NGHI // Kiến nghị
  PHAN_ANH  // Phản ánh
}

enum CapDoToiPham {
  IT_NGHIEM_TRONG          // Ít nghiêm trọng — phạt đến 3 năm (BLHS 2015 Điều 9 khoản 1)
  NGHIEM_TRONG             // Nghiêm trọng — phạt đến 7 năm (Điều 9 khoản 2)
  RAT_NGHIEM_TRONG         // Rất nghiêm trọng — phạt đến 15 năm (Điều 9 khoản 3)
  DAC_BIET_NGHIEM_TRONG    // Đặc biệt nghiêm trọng — phạt trên 15 năm/tử hình (Điều 9 khoản 4)
}

enum LyDoKhongKhoiTo {
  KHONG_CO_SU_VIEC                 // Không có sự việc phạm tội (Điều 157 khoản 1a)
  HANH_VI_KHONG_CAU_THANH_TOI_PHAM // Hành vi không cấu thành tội phạm (Điều 157 khoản 1b)
  NGUOI_THUC_HIEN_CHUA_DU_TUOI    // Người thực hiện chưa đủ tuổi TNHS (Điều 157 khoản 1c)
  NGUOI_PHAM_TOI_CHET              // Người phạm tội đã chết (Điều 157 khoản 1d)
  HET_THOI_HIEU                    // Hết thời hiệu truy cứu TNHS (Điều 157 khoản 1đ)
  TOI_PHAM_DA_DUOC_XOA_AN_TICH    // Tội phạm đã được đại xá (Điều 157 khoản 1e)
  TRUONG_HOP_KHAC                  // Trường hợp khác theo quy định BLTTHS (Điều 157 khoản 1g)
}

// ─────────────────────────────────────────────
// TĐC Report Enums (Phụ lục 08 — BLTTHS 2015)
// ─────────────────────────────────────────────

enum LyDoTamDinhChiVuAn {
  CHUA_XAC_DINH_BI_CAN          // 2.1 Chưa xác định được bị can (Điều 229.1.a)
  KHONG_BIET_BI_CAN_O_DAU       // 2.2 Không biết rõ bị can đang ở đâu, hết thời hạn ĐT (Điều 229.1.b)
  BI_CAN_BENH_TAM_THAN          // 2.3 Bị can bị bệnh tâm thần hoặc hiểm nghèo (Điều 229.1.c)
  CHUA_CO_KET_QUA_GIAM_DINH     // 2.4 Chưa có kết quả trưng cầu giám định (Điều 229.1.d-1)
  CHUA_CO_KET_QUA_DINH_GIA      // 2.5 Chưa có kết quả yêu cầu định giá tài sản (Điều 229.1.d-2)
  CHUA_CO_KET_QUA_TUONG_TRO     // 2.6 Chưa có kết quả yêu cầu nước ngoài tương trợ TP (Điều 229.1.d-3)
  YEU_CAU_TAI_LIEU_CHUA_CO      // 2.7 Đã yêu cầu cung cấp tài liệu nhưng chưa có kết quả (Điều 229.1.đ)
  BAT_KHA_KHANG                 // 2.8 Bất khả kháng: thiên tai, dịch bệnh (Điều 229.1.e)

  @@map("ly_do_tam_dinh_chi_vu_an")
}

enum KetQuaPhucHoiVuAn {
  KET_LUAN_DE_NGHI_TRUY_TO      // 3.3.1 Kết luận điều tra đề nghị truy tố
  DINH_CHI_DIEU_TRA             // 3.3.2 Đình chỉ điều tra
  TAM_DINH_CHI_LAI              // 3.3.3 Tạm đình chỉ điều tra lại
  DANG_DIEU_TRA_XAC_MINH        // 3.3.4 Đang điều tra, xác minh
  CHUYEN_CO_QUAN_DIEU_TRA_KHAC  // 3.3.5 Chuyển cơ quan điều tra khác

  @@map("ket_qua_phuc_hoi_vu_an")
}

enum LyDoTamDinhChiVuViec {
  CHUA_CO_KET_QUA_GIAM_DINH     // 1 Chưa có kết quả trưng cầu giám định
  CHUA_CO_KET_QUA_DINH_GIA      // 2 Chưa có kết quả yêu cầu định giá tài sản
  CHUA_CO_KET_QUA_TUONG_TRO     // 3 Chưa có kết quả yêu cầu nước ngoài tương trợ TP
  YEU_CAU_TAI_LIEU_CHUA_CO      // 4 Đã yêu cầu cung cấp tài liệu nhưng chưa có kết quả
  BAT_KHA_KHANG                 // 5 Bất khả kháng: thiên tai, dịch bệnh
  CAN_CU_KHAC                   // 6 Căn cứ tạm đình chỉ khác

  @@map("ly_do_tam_dinh_chi_vu_viec")
}

enum KetQuaPhucHoiVuViec {
  QUYET_DINH_KHOI_TO            // 3.3.1 Quyết định khởi tố VAHS
  QUYET_DINH_KHONG_KHOI_TO      // 3.3.2 Quyết định không khởi tố VAHS
  TAM_DINH_CHI_LAI              // 3.3.3 Tạm đình chỉ lại
  DANG_XAC_MINH                 // 3.3.4 Đang xác minh
  CHUYEN_CO_QUAN_KHAC           // 3.3.5 Chuyển cơ quan khác

  @@map("ket_qua_phuc_hoi_vu_viec")
}

enum TienDoKhacPhuc {
  DANG_THUC_HIEN  // Đang thực hiện
  DAM_BAO         // Đảm bảo (tính vào row 5.5)
  CHAM_TRE        // Chậm trễ
  KHONG_DAT       // Không đạt

  @@map("tien_do_khac_phuc")
}

enum ReportTdcType {
  VU_AN    // Vụ án tạm đình chỉ điều tra
  VU_VIEC  // Vụ việc tạm đình chỉ giải quyết

  @@map("report_tdc_type")
}

enum ReportTdcStatus {
  DRAFT       // Bản nháp
  REVIEWING   // Đang xét duyệt
  REJECTED    // Bị từ chối
  APPROVED    // Đã phê duyệt
  FINALIZED   // Đã khóa, immutable

  @@map("report_tdc_status")
}

// ─────────────────────────────────────────────
// Case Management
// ─────────────────────────────────────────────

enum CaseStatus {
  TIEP_NHAN        // Tiếp nhận
  DANG_XAC_MINH   // Đang xác minh
  DA_XAC_MINH     // Đã xác minh
  DANG_DIEU_TRA   // Đang điều tra
  TAM_DINH_CHI    // Tạm đình chỉ
  DINH_CHI        // Đình chỉ
  DA_KET_LUAN     // Đã kết luận
  DANG_TRUY_TO    // Đang truy tố
  DANG_XET_XU     // Đang xét xử
  DA_LUU_TRU      // Đã lưu trữ

  @@map("case_status")
}

model Case {
  id             String     @id @default(cuid())
  name           String
  crime          String?
  status         CaseStatus @default(TIEP_NHAN)
  investigatorId String?                          // FK → users (nullable)
  deadline       DateTime?
  unit           String?
  subjectsCount  Int        @default(0)
  metadata       Json?                            // Lưu toàn bộ fields phụ của form (người báo tin, địa chỉ, mã hồ sơ, v.v.)
  capDoToiPham   CapDoToiPham?                    // Mức độ tội phạm (BLHS 2015 Điều 9) — dùng cho KPI-4
  ngayKhoiTo     DateTime?                        // Ngày quyết định khởi tố vụ án
  deletedAt      DateTime?                        // Soft delete
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // TĐC tracking fields (Phụ lục 08)
  laCongNgheCao           Boolean              @default(false)
  lyDoTamDinhChiText      String?              // Backup của giá trị String cũ trước migration
  lyDoTamDinhChiVuAn      LyDoTamDinhChiVuAn?  // Enum mới thay thế lyDoTamDinhChi
  soQuyetDinhTamDinhChi   String?
  ngayTamDinhChi          DateTime?
  soLanTamDinhChi         Int                  @default(0)
  soLanGiaHan             Int                  @default(0)
  daRaSoat                Boolean              @default(false)
  ngayRaSoat              DateTime?
  soQuyetDinhPhucHoi      String?
  ngayPhucHoi             DateTime?
  ketQuaPhucHoiVuAn       KetQuaPhucHoiVuAn?

  investigator   User?       @relation(fields: [investigatorId], references: [id], onDelete: SetNull)
  assignedTeamId String?
  assignedTeam   Team?       @relation("CaseTeam", fields: [assignedTeamId], references: [id], onDelete: SetNull)
  statusHistory  CaseStatusHistory[]
  subjects       Subject[]
  lawyers        Lawyer[]    // TASK-2026-261225
  petitions      Petition[]  @relation("PetitionLinkedCase")
  documents      Document[]  // TASK-2026-022601: Tài liệu liên quan
  linkedIncidents Incident[] @relation("IncidentLinkedCase")
  proposals      Proposal[]
  delegations    Delegation[]
  conclusions    Conclusion[]
  supplements    InvestigationSupplement[]
  vksMeetings    VksMeetingRecord[]
  actionPlans    SuspensionActionPlan[]

  @@index([status])
  @@index([deadline])
  @@index([deletedAt])
  @@index([assignedTeamId])
  @@index([lyDoTamDinhChiVuAn])
  @@map("cases")
}

// ─────────────────────────────────────────────
// Subjects (Đối tượng)
// ─────────────────────────────────────────────

enum SubjectStatus {
  INVESTIGATING  // Đang điều tra
  DETAINED       // Đang tạm giam
  RELEASED       // Đã thả
  WANTED         // Đang truy nã

  @@map("subject_status")
}

enum SubjectType {
  SUSPECT   // Bị can / Bị cáo
  VICTIM    // Bị hại
  WITNESS   // Nhân chứng

  @@map("subject_type")
}

model Subject {
  id            String        @id @default(cuid())
  fullName      String
  dateOfBirth   DateTime
  gender        String        @default("MALE")   // "MALE" | "FEMALE" | "OTHER"
  idNumber      String                            // CCCD/CMND 9 or 12 digits (unique per type per case)
  address       String
  phone         String?
  occupationId  String?       // FK → directories (type=OCCUPATION)
  nationalityId String?       // FK → directories (type=NATIONALITY)
  districtId    String?       // FK → directories (type=DISTRICT) — legacy only
  wardId        String?       // FK → directories (type=WARD)
  districtName  String?       // denormalized: "Quận 1" — preserved at creation time for post-reform display
  caseId        String                            // FK → cases (required)
  crimeId       String                            // FK → directories (type=CRIME, required)
  type          SubjectType   @default(SUSPECT)   // TASK-2026-261225
  status        SubjectStatus @default(INVESTIGATING)
  notes         String?
  deletedAt     DateTime?                         // Soft delete
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  case          Case          @relation(fields: [caseId], references: [id])
  lawyers       Lawyer[]      // Lawyers assigned to this subject

  @@index([caseId])
  @@index([crimeId])
  @@index([status])
  @@index([type])
  @@index([deletedAt])
  @@map("subjects")
}

// ─────────────────────────────────────────────
// Lawyer (Luật sư) — TASK-2026-261225
// ─────────────────────────────────────────────

model Lawyer {
  id          String    @id @default(cuid())
  fullName    String
  lawFirm     String?                          // Văn phòng luật sư
  barNumber   String    @unique                // Số thẻ luật sư
  phone       String?
  caseId      String                           // FK → cases (required)
  subjectId   String?                          // FK → subjects (nullable — one lawyer can defend multiple)
  deletedAt   DateTime?                        // Soft delete
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  case        Case      @relation(fields: [caseId], references: [id])
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([subjectId])
  @@index([deletedAt])
  @@map("lawyers")
}

// ─────────────────────────────────────────────
// Petition (Đơn thư KNTC) — TASK-2026-260202
// ─────────────────────────────────────────────

enum PetitionStatus {
  MOI_TIEP_NHAN    // Mới tiếp nhận
  DANG_XU_LY      // Đang xử lý
  CHO_PHE_DUYET   // Chờ phê duyệt
  DA_LUU_DON      // Đã lưu đơn
  DA_GIAI_QUYET   // Đã giải quyết
  DA_CHUYEN_VU_VIEC // Đã chuyển thành Vụ việc
  DA_CHUYEN_VU_AN  // Đã chuyển thành Vụ án

  @@map("petition_status")
}

model Petition {
  id                String         @id @default(cuid())
  // Số tiếp nhận — duy nhất, format: DT-{YEAR}-{SEQ}
  stt               String         @unique
  // Ngày tiếp nhận
  receivedDate      DateTime
  // Đơn vị tiếp nhận
  unit              String?
  // Người nhập
  enteredById       String?        // FK → users
  // Người gửi đơn
  senderName        String
  senderBirthYear   String?
  senderAddress     String?
  senderPhone       String?
  senderEmail       String?
  // Nghi vấn đối tượng
  suspectedPerson   String?
  suspectedAddress  String?
  // Nội dung đơn
  petitionType      LoaiDon?       // Loại đơn (Luật Tố cáo 2018 / Khiếu nại 2011)
  priority          String?        // Mức độ ưu tiên: Cao, Trung bình, Thấp
  summary           String?
  detailContent     String?
  attachmentsNote   String?        // Ghi chú tài liệu đính kèm (file storage out-of-scope)
  // Phân công
  deadline          DateTime?
  assignedToId      String?        // FK → users
  notes             String?
  // Trạng thái
  status            PetitionStatus @default(MOI_TIEP_NHAN)
  // Liên kết sau khi chuyển đổi
  linkedCaseId      String?        // FK → cases (sau khi chuyển thành Vụ án)
  linkedIncidentId  String?        // FK → incidents (sau khi chuyển thành Vụ việc)
  // Soft delete
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  enteredBy         User?          @relation("PetitionEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  assignedTo        User?          @relation("PetitionAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  linkedCase        Case?          @relation("PetitionLinkedCase", fields: [linkedCaseId], references: [id], onDelete: SetNull)
  linkedIncident    Incident?      @relation("PetitionLinkedIncident", fields: [linkedIncidentId], references: [id], onDelete: SetNull)
  assignedTeamId    String?
  assignedTeam      Team?          @relation("PetitionTeam", fields: [assignedTeamId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([receivedDate])
  @@index([deadline])
  @@index([senderName])
  @@index([deletedAt])
  @@index([assignedTeamId])
  @@map("petitions")
}

// ─────────────────────────────────────────────
// Incident (Vụ việc) — TASK-2026-260202
// ─────────────────────────────────────────────

enum IncidentStatus {
  TIEP_NHAN           // Tiếp nhận
  DANG_XAC_MINH       // Đang xác minh
  DA_PHAN_CONG        // Đã lên phân công
  DA_GIAI_QUYET       // Đã giải quyết
  TAM_DINH_CHI        // Tạm đình chỉ
  QUA_HAN             // Quá hạn
  DA_CHUYEN_VU_AN     // Đã chuyển thành vụ án (khởi tố)
  KHONG_KHOI_TO       // Không khởi tố
  CHUYEN_XPHC         // Chuyển xử phạt hành chính
  TDC_HET_THOI_HIEU   // TĐC hết thời hiệu
  TDC_HTH_KHONG_KT    // TĐC hết thời hạn không khởi tố
  PHUC_HOI_NGUON_TIN  // Phục hồi nguồn tin tố phạm
  DA_CHUYEN_DON_VI    // Đã chuyển đơn vị khác
  DA_NHAP_VU_KHAC     // Đã nhập vào vụ việc khác
  PHAN_LOAI_DAN_SU    // Phân loại dân sự

  @@map("incident_status")
}

model Incident {
  id              String         @id @default(cuid())
  code            String         @unique  // VV-{YEAR}-{SEQ}
  name            String
  incidentType    String?        // Loại vụ việc
  description     String?
  fromDate        DateTime?      // Ngày bắt đầu vụ việc
  toDate          DateTime?      // Ngày xảy ra/kết thúc vụ việc
  deadline        DateTime?      // Hạn xử lý
  unitId          String?        // ID đơn vị thụ lý
  investigatorId  String?        // ID Điều tra viên thụ lý
  status          IncidentStatus @default(TIEP_NHAN)
  sourcePetitionId String?       // Nguồn gốc nếu từ đơn thư

  // Thông tin nguồn tin (Đ.144 BLTTHS 2015)
  doiTuongCaNhan    String?      // Đối tượng bị tố giác (TT119 Mẫu 01)
  doiTuongToChuc    String?      // Tổ chức liên quan
  loaiDonVu         LoaiNguonTin? // Loại nguồn tin (Điều 144 BLTTHS 2015)
  benVu             String?      // Người tố giác/báo tin (Đ.144 BLTTHS)
  donViGiaiQuyet    String?      // Đơn vị thụ lý (Đ.145 BLTTHS)
  ngayDeXuat        DateTime?    // Ngày tiếp nhận nguồn tin (Đ.146 BLTTHS)
  ketQuaXuLy        String?      // Kết quả giải quyết nguồn tin
  tinhTrangHoSo     String?      // Tình trạng hồ sơ
  tinhTrangThoiHieu String?      // Tình trạng thời hiệu truy cứu TNHS
  nguoiQuyetDinh    String?      // Người ra quyết định (Thủ trưởng/Phó TT CQĐT)
  chuyenDenDonVi    String?      // Đơn vị được chuyển đến
  chuyenTuDonVi     String?      // Đơn vị chuyển đi (audit trail)

  // Thông tin nghiệp vụ bổ sung theo BLTTHS
  soQuyetDinh       String?      // Số quyết định (khởi tố/không khởi tố/TĐC/phục hồi)
  ngayQuyetDinh     DateTime?    // Ngày ra quyết định
  soLanGiaHan       Int          @default(0) // Số lần đã gia hạn, tối đa 2 (Điều 147 khoản 2-3)
  ngayGiaHan        DateTime?              // Ngày gia hạn gần nhất
  lyDoKhongKhoiTo   LyDoKhongKhoiTo? // Lý do không khởi tố (Điều 157 BLTTHS 2015: 7 căn cứ)
  lyDoTamDinhChiText String?     // Backup của giá trị String cũ trước migration
  lyDoTamDinhChiVuViec LyDoTamDinhChiVuViec? // Enum mới cho vụ việc
  laCongNgheCaoVV   Boolean      @default(false)
  soQuyetDinhTamDinhChiVV String?
  ngayTamDinhChiVV  DateTime?
  soLanTamDinhChiVV Int          @default(0)
  daRaSoatVV        Boolean      @default(false)
  ngayRaSoatVV      DateTime?
  soQuyetDinhPhucHoiVV String?
  ngayPhucHoiVV     DateTime?
  ketQuaPhucHoiVuViec KetQuaPhucHoiVuViec?
  diaChiXayRa       String?      // Địa điểm xảy ra sự việc
  // Thông tin người tố giác/báo tin chi tiết
  sdtNguoiToGiac    String?      // SĐT người tố giác
  diaChiNguoiToGiac String?      // Địa chỉ người tố giác
  cmndNguoiToGiac   String?      // CCCD/CMND người tố giác

  // Self-reference: nhập vào vụ khác
  mergedIntoId      String?
  mergedInto        Incident?    @relation("IncidentMerge", fields: [mergedIntoId], references: [id])
  mergedFrom        Incident[]   @relation("IncidentMerge")

  // Liên kết rõ ràng với Case sau khởi tố
  linkedCaseId      String?
  linkedCase        Case?        @relation("IncidentLinkedCase", fields: [linkedCaseId], references: [id])

  // Cán bộ nhập (FK)
  canBoNhapId       String?
  canBoNhap         User?        @relation("IncidentCanBoNhap", fields: [canBoNhapId], references: [id])

  // Người tạo
  createdById       String?
  createdBy         User?        @relation("IncidentCreatedBy", fields: [createdById], references: [id])

  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  investigator    User?          @relation("IncidentInvestigator", fields: [investigatorId], references: [id], onDelete: SetNull)
  assignedTeamId  String?
  assignedTeam    Team?          @relation("IncidentTeam", fields: [assignedTeamId], references: [id], onDelete: SetNull)
  petitions       Petition[]     @relation("PetitionLinkedIncident")
  documents       Document[]     // Tài liệu liên quan
  statusHistory   IncidentStatusHistory[]
  vksMeetings     VksMeetingRecord[] @relation("IncidentVksMeetings")
  actionPlans     SuspensionActionPlan[] @relation("IncidentActionPlans")

  @@index([status])
  @@index([deletedAt])
  @@index([assignedTeamId])
  @@index([ngayDeXuat])
  @@index([lyDoTamDinhChiVuViec])
  @@map("incidents")
}

// ─────────────────────────────────────────────
// Incident Status History
// ─────────────────────────────────────────────

model IncidentStatusHistory {
  id          String         @id @default(cuid())
  incidentId  String
  incident    Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  fromStatus  IncidentStatus
  toStatus    IncidentStatus
  changedById String
  changedBy   User           @relation("IncidentStatusChangedBy", fields: [changedById], references: [id])
  note        String?        // Lý do thay đổi
  createdAt   DateTime       @default(now())

  @@index([incidentId])
  @@map("incident_status_history")
}

// ─────────────────────────────────────────────
// Document (Tài liệu/Hồ sơ) — TASK-2026-022601
// ─────────────────────────────────────────────

enum DocumentType {
  VAN_BAN     // Văn bản
  HINH_ANH    // Hình ảnh
  VIDEO       // Video
  AM_THANH    // Âm thanh
  KHAC        // Khác

  @@map("document_type")
}

model Document {
  id          String       @id @default(cuid())
  title       String       // Tiêu đề tài liệu
  description String?      // Mô tả
  fileName    String       // Tên file lưu trữ
  originalName String      // Tên file gốc
  mimeType    String       // MIME type
  size        Int          // Kích thước file (bytes)
  filePath    String       // Đường dẫn file (local storage)
  documentType DocumentType @default(VAN_BAN)
  
  // Liên kết
  caseId      String?      // FK → cases (nullable)
  incidentId  String?      // FK → incidents (nullable)
  uploadedById String      // FK → users (required)
  
  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  case        Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  incident    Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  uploadedBy  User         @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@index([incidentId])
  @@index([uploadedById])
  @@index([documentType])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("documents")
}

// ─────────────────────────────────────────────
// Proposal (Đề xuất VKS) — Workflow SCR-PF-05
// ─────────────────────────────────────────────

enum ProposalStatus {
  CHO_GUI      // Chờ gửi
  DA_GUI       // Đã gửi
  CO_PHAN_HOI  // Đã có phản hồi
  DA_XU_LY    // Đã xử lý

  @@map("proposal_status")
}

model Proposal {
  id             String         @id @default(cuid())
  proposalNumber String         @unique // Format: DX-{YEAR}-{SEQ}
  relatedCaseId  String?        // FK → cases (nullable)
  caseType       String?        // "Vụ án" | "Vụ việc" | "Đơn thư"
  content        String         // Nội dung đề xuất
  unit           String?        // Đơn vị gửi
  createdById    String?        // FK → users
  status         ProposalStatus @default(CHO_GUI)
  sentDate       DateTime?      // Ngày gửi VKS
  response       String?        // Nội dung phản hồi
  responseDate   DateTime?      // Ngày có phản hồi
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  relatedCase    Case?          @relation(fields: [relatedCaseId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("ProposalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([deletedAt])
  @@map("proposals")
}

// ─────────────────────────────────────────────
// GuidanceRecord (Hướng dẫn đơn thư) — Workflow SCR-PF-02
// ─────────────────────────────────────────────

enum GuidanceStatus {
  PENDING    // Đang chờ
  COMPLETED  // Đã hoàn thành
  CANCELLED  // Đã hủy

  @@map("guidance_status")
}

model GuidanceRecord {
  id               String         @id @default(cuid())
  date             DateTime       @default(now())
  unit             String?
  createdById      String?        // FK → users
  guidedPerson     String         // Tên người được hướng dẫn
  guidedPersonPhone String?       // SĐT người được hướng dẫn
  subject          String?        // Chủ đề hướng dẫn
  guidanceContent  String         // Nội dung hướng dẫn
  notes            String?
  status           GuidanceStatus @default(PENDING)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  createdBy        User?          @relation("GuidanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([deletedAt])
  @@map("guidance_records")
}

// ─────────────────────────────────────────────
// Exchange + ExchangeMessage (Trao đổi công văn) — Workflow SCR-PF-03
// ─────────────────────────────────────────────

enum ExchangeStatus {
  OPEN       // Đang mở
  CLOSED     // Đã đóng
  PENDING    // Chờ xử lý

  @@map("exchange_status")
}

model Exchange {
  id           String         @id @default(cuid())
  recordCode   String?        // Mã hồ sơ liên quan
  recordType   String?        // "Vụ án" | "Vụ việc" | "Đơn thư"
  senderUnit   String?        // Đơn vị gửi
  receiverUnit String?        // Đơn vị nhận
  subject      String?        // Tiêu đề trao đổi
  status       ExchangeStatus @default(OPEN)
  createdById  String?        // FK → users
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdBy    User?          @relation("ExchangeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  messages     ExchangeMessage[]

  @@index([status])
  @@index([deletedAt])
  @@map("exchanges")
}

model ExchangeMessage {
  id          String   @id @default(cuid())
  exchangeId  String   // FK → exchanges
  senderId    String?  // FK → users
  content     String
  attachments Json?    // [{ id, name, size, type, url }]
  createdAt   DateTime @default(now())

  exchange    Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  sender      User?    @relation("ExchangeMessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([exchangeId])
  @@map("exchange_messages")
}

// ─────────────────────────────────────────────
// Delegation (Ủy thác điều tra) — Workflow SCR-PF-04
// ─────────────────────────────────────────────

enum DelegationStatus {
  PENDING    // Chờ xử lý
  RECEIVED   // Đã nhận
  COMPLETED  // Đã hoàn thành

  @@map("delegation_status")
}

model Delegation {
  id              String           @id @default(cuid())
  delegationNumber String          @unique // Format: UT-{SEQ}/{YEAR}
  delegationDate  DateTime         @default(now())
  receivingUnit   String           // Đơn vị nhận ủy thác
  content         String           // Nội dung ủy thác
  createdById     String?          // FK → users
  status          DelegationStatus @default(PENDING)
  completedDate   DateTime?
  relatedCaseId   String?          // FK → cases
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  createdBy       User?            @relation("DelegationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  relatedCase     Case?            @relation(fields: [relatedCaseId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([deletedAt])
  @@map("delegations")
}

// ─────────────────────────────────────────────
// Conclusion (Kết luận điều tra) — CaseDetailPage
// ─────────────────────────────────────────────

enum ConclusionStatus {
  DU_THAO    // Dự thảo
  CHO_DUYET  // Chờ duyệt
  DA_DUYET   // Đã duyệt

  @@map("conclusion_status")
}

model Conclusion {
  id           String            @id @default(cuid())
  caseId       String            // FK → cases (required)
  type         String            // Loại kết luận: "Kết luận sơ bộ", "Kết luận chính thức", ...
  content      String            // Nội dung kết luận
  authorId     String?           // FK → users (người soạn)
  approvedById String?           // FK → users (người duyệt)
  status       ConclusionStatus  @default(DU_THAO)
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  case         Case              @relation(fields: [caseId], references: [id])
  author       User?             @relation("ConclusionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  approvedBy   User?             @relation("ConclusionApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([status])
  @@index([deletedAt])
  @@map("conclusions")
}

// ─────────────────────────────────────────────
// Case Status History
// ─────────────────────────────────────────────

model CaseStatusHistory {
  id          String     @id @default(cuid())
  caseId      String
  fromStatus  CaseStatus?           // null nếu là lần đầu tiên (tạo mới)
  toStatus    CaseStatus
  changedById String?               // FK → users (nullable)
  changedAt   DateTime   @default(now())

  case        Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  changedBy   User?      @relation("StatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([changedAt])
  @@map("case_status_history")
}

// ─────────────────────────────────────────────
// Investigation Supplement (Điều tra bổ sung / Điều tra lại)
// TASK-2026-0227-001
// ─────────────────────────────────────────────

model InvestigationSupplement {
  id               String    @id @default(cuid())
  caseId           String
  type             String    // "Điều tra bổ sung" | "Điều tra lại"
  decisionNumber   String
  decisionDate     DateTime?
  reason           String
  deadline         DateTime?
  createdById      String?
  createdAt        DateTime  @default(now())

  case             Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy        User?     @relation("SupplementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([createdAt])
  @@map("investigation_supplements")
}

// ─────────────────────────────────────────────
// Audit Log
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g. "USER_LOGIN", "USER_LOGOUT", "CASE_CREATED"
  subject   String?  // entity type affected
  subjectId String?  // entity id affected
  metadata  Json?    // additional context (IP, user-agent, etc.)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([subjectId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

enum NotificationType {
  CASE_STATUS_CHANGED
  CASE_DEADLINE_NEAR
  CASE_OVERDUE
  CASE_ASSIGNED
  PETITION_RECEIVED
  PETITION_DEADLINE_NEAR
  PETITION_OVERDUE
  INCIDENT_DEADLINE_NEAR
  INCIDENT_OVERDUE
  DOCUMENT_UPLOADED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?          // optional deep-link URL
  metadata  Json?            // extra context (caseId, petitionId, etc.)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// MasterClass (Phân loại danh mục)
// Type codes: 00=Giới tính, 01=Loại vụ việc, 02=Loại đơn thư,
// 03=Mức độ ưu tiên, 04=Nhóm tuổi, 05=Trình độ học vấn,
// 06=Loại vật chứng, 07=Phân loại vụ án, 08=Viện Kiểm sát
// ─────────────────────────────────────────────

model MasterClass {
  id        String   @id @default(cuid())
  type      String   // "00", "01", "02"...
  code      String   // "NAM", "NU", "TC"...
  name      String   // "Nam", "Nữ", "Tố cáo"...
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, code])
  @@index([type])
  @@index([isActive])
  @@map("master_classes")
}

// ─────────────────────────────────────────────
// Team (Tổ/Nhóm/Đơn vị)
// ─────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  level     Int      @default(0)
  parentId  String?
  parent    Team?    @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Team[]   @relation("TeamHierarchy")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          UserTeam[]
  casesAssigned    Case[]             @relation("CaseTeam")
  petitionsAssigned Petition[]        @relation("PetitionTeam")
  incidentsAssigned Incident[]        @relation("IncidentTeam")
  grantsForUnit    DataAccessGrant[]  @relation("GrantUnit")

  @@index([parentId])
  @@index([level])
  @@map("teams")
}

// ─────────────────────────────────────────────
// UserTeam (Thành viên tổ/nhóm)
// ─────────────────────────────────────────────

model UserTeam {
  userId   String
  teamId   String
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@index([teamId])
  @@map("user_teams")
}

// ─────────────────────────────────────────────
// Data Access Grant (Ủy quyền truy cập dữ liệu)
// ─────────────────────────────────────────────

enum AccessLevel {
  READ
  WRITE
}

model DataAccessGrant {
  id          String      @id @default(cuid())
  granteeId   String
  teamId      String
  accessLevel AccessLevel
  grantedById String
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())

  grantee   User @relation("GrantReceived", fields: [granteeId], references: [id], onDelete: Cascade)
  team      Team @relation("GrantUnit", fields: [teamId], references: [id], onDelete: Cascade)
  grantedBy User @relation("GrantGiven", fields: [grantedById], references: [id], onDelete: Cascade)

  @@unique([granteeId, teamId, accessLevel])
  @@index([granteeId])
  @@map("data_access_grants")
}

// ─────────────────────────────────────────────
// OTP Code (Email OTP for 2FA fallback)
// ─────────────────────────────────────────────

model OtpCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  salt      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  purpose   String    @default("TWO_FA")  // "TWO_FA" | "PASSWORD_RESET"

  @@index([userId])
  @@map("otp_codes")
}

// ─────────────────────────────────────────────
// System Settings (Cấu hình thời hạn xử lý theo BLTTHS)
// ─────────────────────────────────────────────

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique   // Mã cấu hình
  value       String              // Giá trị (string, parse khi dùng)
  label       String              // Mô tả tiếng Việt
  unit        String?             // Đơn vị: "ngay", "thang", "lan"
  legalBasis  String?             // Cơ sở pháp lý (Điều luật)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("system_settings")
}

// ─────────────────────────────────────────────
// Feature Flags (module bật/tắt runtime + feature pack)
// ─────────────────────────────────────────────

model FeatureFlag {
  key         String   @id                   // e.g. "cases", "petitions", "incidents"
  label       String                          // Tên hiển thị tiếng Việt
  description String?                         // Mô tả ngắn
  enabled     Boolean  @default(true)         // Bật/tắt toàn cục
  domain      String?                         // Bounded context: "case-domain", "org-domain"...
  rolloutPct  Int      @default(100)          // 0-100, dự phòng gradual rollout
  metadata    Json?                           // Tuỳ biến (routes, permissions)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([enabled])
  @@map("feature_flags")
}

// ─────────────────────────────────────────────
// User Abbreviations (Text Expansion)
// ─────────────────────────────────────────────

model UserAbbreviation {
  id        String   @id @default(cuid())
  userId    String
  shortcut  String
  expansion String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shortcut])
  @@index([userId])
  @@map("user_abbreviations")
}

// ─────────────────────────────────────────────
// Push Notifications — FCM Devices
// ─────────────────────────────────────────────

model UserDevice {
  id        String   @id @default(cuid())
  userId    String
  fcmToken  String   @unique
  platform  String   // "android" | "ios"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_devices")
}

// ─────────────────────────────────────────────
// Push Notifications — Overdue Dedup Table
// ─────────────────────────────────────────────

model OverdueNotification {
  id           String   @id @default(cuid())
  resourceType String   // "case" | "incident" | "petition"
  resourceId   String
  userId       String
  notifiedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId, userId])
  @@index([notifiedAt])
  @@map("overdue_notifications")
}

// ─────────────────────────────────────────────
// TĐC Report Sub-Models (Phụ lục 08)
// ─────────────────────────────────────────────

model VksMeetingRecord {
  id             String    @id @default(cuid())
  caseId         String?
  incidentId     String?
  ngayTrao       DateTime
  noiDung        String
  soQuyetDinh    String?
  ketQua         String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  case           Case?     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  incident       Incident? @relation("IncidentVksMeetings", fields: [incidentId], references: [id], onDelete: Cascade)
  createdBy      User      @relation("VksMeetingCreatedBy", fields: [createdById], references: [id])

  @@index([caseId])
  @@index([incidentId])
  @@map("vks_meeting_records")
}

model SuspensionActionPlan {
  id             String           @id @default(cuid())
  caseId         String?
  incidentId     String?
  ngayLap        DateTime
  bienPhap       String
  thoiHan        DateTime?
  tienDo         TienDoKhacPhuc   @default(DANG_THUC_HIEN)
  ketQua         String?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  case           Case?            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  incident       Incident?        @relation("IncidentActionPlans", fields: [incidentId], references: [id], onDelete: Cascade)
  createdBy      User             @relation("ActionPlanCreatedBy", fields: [createdById], references: [id])

  @@index([caseId])
  @@index([incidentId])
  @@map("suspension_action_plans")
}

model ReportTdcDraft {
  id             String          @id @default(cuid())
  loaiBaoCao     ReportTdcType
  fromDate       DateTime
  toDate         DateTime
  teamIds        String[]
  status         ReportTdcStatus @default(DRAFT)
  computedData   Json
  adjustedData   Json?
  notes          String?

  createdById    String
  reviewedById   String?
  approvedById   String?
  rejectedById   String?
  createdAt      DateTime        @default(now())
  reviewedAt     DateTime?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?
  finalizedAt    DateTime?

  createdBy      User            @relation("ReportCreatedBy",   fields: [createdById],   references: [id])
  reviewedBy     User?           @relation("ReportReviewedBy",  fields: [reviewedById],  references: [id])
  approvedBy     User?           @relation("ReportApprovedBy",  fields: [approvedById],  references: [id])
  rejectedBy     User?           @relation("ReportRejectedBy",  fields: [rejectedById],  references: [id])

  @@index([loaiBaoCao])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("report_tdc_drafts")
}
