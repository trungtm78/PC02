# =============================================================
# PC02 Case Management — Production Environment Template
# Copy to .env and fill in real values before running Docker.
# NEVER commit .env with real secrets.
# =============================================================

# ── PostgreSQL ──────────────────────────────────────────────
DB_USER=pc02_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=pc02_db

# ── JWT (RS256) ──────────────────────────────────────────────
# Keys are mounted from ./keys/private.pem + ./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ── 2FA TOTP ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── Seed passwords ───────────────────────────────────────────
SEED_ADMIN_PASSWORD=CHANGE_ME_MIN_12_CHARS
SEED_OFFICER_PASSWORD=CHANGE_ME_MIN_12_CHARS

# ── CORS ─────────────────────────────────────────────────────
# Set to your server IP or domain (comma-separated for multiple)
CORS_ORIGIN=http://YOUR_SERVER_IP

# ── SMTP (optional — for 2FA email OTP) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pc02.local
