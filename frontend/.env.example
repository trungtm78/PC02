# PC02 frontend env vars — copy to `.env.local` for dev or set in CI for prod.
# All variables MUST be prefixed `VITE_` so Vite exposes them to client bundle.

# ── Mobile app download ─────────────────────────────────────────────────────
# Surfaced on LoginPage "Tải ứng dụng di động" section.
# Leave empty until the corresponding distribution channel is live; the UI
# renders a "Sắp ra mắt" placeholder instead of a broken QR.
VITE_MOBILE_ANDROID_URL=
VITE_MOBILE_IOS_URL=
